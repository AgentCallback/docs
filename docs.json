{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "AgentCallback Documentation",
  "description": "Learn how to set up AgentCallback, collaborate with your team, and create AI voice agents.",
  "colors": {
    "primary": "#2563EB",
    "light": "#60A5FA",
    "dark": "#1D4ED8"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Get started",
          "icon": "rocket",
          "href": "/get-started/sign-up"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Get started",
        "icon": "rocket",
        "expanded": true,
        "pages": [
          "get-started/sign-up",
          "get-started/manage-your-team",
          "get-started/create-a-voice-agent"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://agentcallback.ai/sign-in"
    }
  }
}
